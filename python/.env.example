# ============================================================
# Marketing Data Connector — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# Only configure the connectors you intend to use.
# ============================================================

# --- General ---
DAYS_BACK=30

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- GA4 (Google Analytics 4) ---
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Google Guaranteed (Local Services Ads) ---
GOOGLE_GUARANTEED_CLIENT_ID=
GOOGLE_GUARANTEED_CLIENT_SECRET=
GOOGLE_GUARANTEED_REFRESH_TOKEN=

# --- Google Business Profile ---
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REFRESH_TOKEN=

# --- Facebook Ads ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT_ID=

# --- Instagram ---
# Uses Facebook Graph API — needs a Facebook Page connected to IG Business Account
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- YouTube ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# --- BigQuery ---
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_ID=marketing_data
BIGQUERY_LOCATION=US
